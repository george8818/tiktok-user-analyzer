# =============================================================================
# TikTok User Analyzer - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# --- LLM Configuration ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
# Model for text analysis (user profiling, Q&A)
LLM_MODEL=claude-sonnet-4-20250514
# Model for vision/multimodal analysis (video frame analysis)
VISION_MODEL=claude-sonnet-4-20250514
# Max tokens for LLM responses
LLM_MAX_TOKENS=4096
# Temperature for generation
LLM_TEMPERATURE=0.3

# --- Scraper Configuration ---
# Browser to use for scraping (chromium, firefox, webkit)
BROWSER_TYPE=chromium
# Whether to run browser in headless mode
HEADLESS=true
# Request timeout in seconds
SCRAPER_TIMEOUT=30
# Max retries for failed requests
SCRAPER_MAX_RETRIES=3
# Delay between requests (seconds) to avoid rate limiting
SCRAPER_REQUEST_DELAY=2.0

# --- Storage Configuration ---
# Database URL (SQLite for local, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./data/tiktok_analyzer.db
# Directory for downloaded videos and extracted frames
MEDIA_DIR=./data/media
# Directory for generated reports
REPORTS_DIR=./data/reports

# --- API Configuration ---
API_HOST=0.0.0.0
API_PORT=8000
# Enable debug mode
DEBUG=false
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# --- Agent Configuration ---
# Max conversation history turns to keep
MAX_CONVERSATION_TURNS=20
# Number of video frames to extract per video
FRAMES_PER_VIDEO=5
# Max number of videos to analyze per user
MAX_VIDEOS_PER_USER=2

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
